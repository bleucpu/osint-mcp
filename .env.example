# Copy this file to `.env` and fill in. The .env file is loaded automatically
# at startup. All values can also be set as real environment variables; the
# process environment wins over .env if both are set.

# ─── Discord routing ────────────────────────────────────────────────────────
# Required: at least the firehose webhook. Per-kind overrides optional —
# unset kinds fall back to the firehose.

DISCORD_WEBHOOK_FIREHOSE=

# Optional per-kind overrides. Set any subset.
#DISCORD_WEBHOOK_RECON=          # new subdomains, ports, certs
#DISCORD_WEBHOOK_NEWS=           # blog posts, changelogs, GitHub releases
#DISCORD_WEBHOOK_SCOPE=          # H1 / Bugcrowd program changes
#DISCORD_WEBHOOK_SECRETS=        # leaked keys (private channel recommended)
#DISCORD_WEBHOOK_JS=             # JS bundle changes / new endpoints
#DISCORD_WEBHOOK_SOCIAL=         # twitter / social

# ─── Optional API keys ──────────────────────────────────────────────────────
# Everything below is optional. Without them the system runs with reduced
# signal — no scope-diff, no GitHub secret scan, no Twitter, no LLM summaries.

# HackerOne scope-diff watcher (BOTH required — official API only,
# we do not scrape hackerone.com under any circumstances)
#HACKERONE_API_USERNAME=
#HACKERONE_API_TOKEN=

# Bugcrowd scope-diff watcher (official Researcher API, requires Bugcrowd
# to have approved your token — see https://docs.bugcrowd.com/api/)
#BUGCROWD_API_TOKEN=

#GITHUB_TOKEN=                   # higher rate limits + secret scan (Phase 3, official GitHub API)
#ANTHROPIC_API_KEY=              # feed_summary LLM endpoint
#CERTSTREAM_URL=                 # override default certstream.calidog.io
#CERTSTREAM_DISABLED=1           # opt out of the certstream watcher entirely

# ─── Logging ────────────────────────────────────────────────────────────────
#OSINT_MCP_LOG_LEVEL=INFO        # DEBUG / INFO / WARNING / ERROR
